<?xml version="1.0"?>
<robot name="jr_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find jr_bot_description)/urdf/jr_bot.ros2_control.xacro" />
    
    <xacro:jr_bot_ros2_control device_addr="/dev/ttyACM0" />

    <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
    </material>
    <material name="blue">
        <color rgba="0.0 0.3 0.8 1.0"/>
    </material>
    <material name="white">
        <color rgba="0.9 0.9 0.9 1.0"/>
    </material>

    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.20 0.14 0.05"/> </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.20 0.14 0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.00184" iyy="0.00354" izz="0.00496" ixy="0.0" iyz="0.0" ixz="0.0"/>
        </inertial>
    </link>

    <joint name="base_footprint_to_base_link" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 0.04" rpy="0 0 0" /> </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.02"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.04" length="0.02"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="4.3e-05" iyy="4.3e-05" izz="8e-05" ixy="0.0" iyz="0.0" ixz="0.0"/>
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="-0.05 0.08 -0.01" rpy="-1.5707 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.02"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.04" length="0.02"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="4.3e-05" iyy="4.3e-05" izz="8e-05" ixy="0.0" iyz="0.0" ixz="0.0"/>
        </inertial>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="-0.05 -0.08 -0.01" rpy="1.5707 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="0.02"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.02"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="8e-06" iyy="8e-06" izz="8e-06" ixy="0.0" iyz="0.0" ixz="0.0"/>
        </inertial>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel"/>
        <origin xyz="0.08 0 -0.02" rpy="0 0 0"/> 
    </joint>

    <link name="tof_link">
        <visual>
            <geometry>
                <box size="0.02 0.04 0.02"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="tof_joint" type="fixed">
        <parent link="base_link"/>
        <child link="tof_link"/>
        <origin xyz="0.10 0 0.035" rpy="0 0 0"/>
    </joint>

    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.01 0.01 0.005"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0.025" rpy="0 0 0"/> 
    </joint>

</robot>