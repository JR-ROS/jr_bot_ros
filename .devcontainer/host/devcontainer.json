{
    "name": "Host PC",
    "dockerFile": "Dockerfile",

    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/src,type=bind",
    "workspaceFolder": "/workspaces",

    "privileged": true,

    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}"
    },

    "remoteUser": "ubuntu",

    "runArgs": [
        // "--device=/dev/int-brain-xxxxxxxxx",     // UPDATE THIS WITH THE ACTUAL DEVICE NAME
        "--net=host",
        "--ipc=host",
        "--name=intbrain-dev-img"
    ],
    
    "initializeCommand": "xhost +local:root",
    "postCreateCommand": "sudo chown -R ubuntu:ubuntu /workspaces && /workspaces/src/scripts/post_create.sh"
}