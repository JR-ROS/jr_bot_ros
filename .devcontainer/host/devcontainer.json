{
    "name": "Host PC",
    "image": "ghcr.io/eccentricorange/int_brain_host:amd64-dev0.4",

    "workspaceMount": "source=${localWorkspaceFolder},target=/home/ubuntu/int_brain_ws,type=bind",
    "workspaceFolder": "/home/ubuntu/int_brain_ws",

    "privileged": true,

    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}"
    },

    "remoteUser": "ubuntu",

    "runArgs": [
        "--net=host",
        "--ipc=host",
        "--name=int_brain_dev",
        "--volume=/dev:/dev"
    ],
    
    "initializeCommand": "xhost +local:root",
    "postCreateCommand": "sudo chown -R ubuntu:ubuntu $WORKSPACE && $WORKSPACE/config/scripts/post_create.sh"
}