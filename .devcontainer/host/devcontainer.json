{
    "name": "Host PC",
    "image": "ghcr.io/eccentricorange/int_brain_host:amd64-dev0.5",

    "workspaceMount": "source=${localWorkspaceFolder},target=/home/ubuntu/int_brain_ws/src,type=bind",
    "workspaceFolder": "/home/ubuntu/int_brain_ws",

    "privileged": true,

    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}"
    },

    "remoteUser": "ubuntu",

    "runArgs": [
        "--net=host",
        "--ipc=host",
        "--name=int_brain_dev",
        "--volume=/dev:/dev"
    ],
    
    "initializeCommand": "git submodule update --init --recursive --remote && xhost +local:root",
    "postCreateCommand": "$WORKSPACE/src/config/scripts/post_create.sh"
}