{
    "name": "Integrated Brain SBC Development Environment",
    "dockerFile": "Dockerfile",

    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/src,type=bind",
    "workspaceFolder": "/workspaces",

    "privileged": true,

    "containerEnv": {
    },

    "remoteUser": "ubuntu",

    "runArgs": [
        // "--device=/dev/int-brain-xxxxxxxxx",
        "--net=host",
        "--ipc=host",
        "--name=intbrain-dev-img"
    ],
    "postCreateCommand": "sudo chown -R ubuntu:ubuntu /workspaces && /workspaces/src/scripts/post_create.sh",
}